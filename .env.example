# ── Pinata IPFS (optional) ──
# Enables in-app IPFS uploads for job deliverables.
# Create a JWT at https://app.pinata.cloud (API Keys → New Key).
# Copy this file to ".env" and fill in your values. Never commit ".env".

# Server-side only — never exposed to the browser.
PINATA_JWT=

# Optional: your dedicated Pinata gateway (defaults to gateway.pinata.cloud).
# Example: https://your-subdomain.mypinata.cloud
PINATA_GATEWAY=
